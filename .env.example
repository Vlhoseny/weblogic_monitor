# =============================================================================
# WebLogic Health Monitor - Configuration
# =============================================================================
# Copy this file to .env and fill in YOUR values.
#   copy .env.example .env
# Then edit .env with notepad.
# =============================================================================

# --- WebLogic Admin Server ------------------------------------------
# Change the URL if your Admin Server is on a different host/port.
WL_ADMIN_URL=t3://127.0.0.1:7101
WL_ADMIN_USER=weblogic
WL_ADMIN_PASS=                          # <-- YOUR WebLogic admin password

# --- Gmail SMTP -----------------------------------------------------
# You MUST use a Gmail App Password, NOT your regular password.
# How to get one: https://support.google.com/accounts/answer/185833
WL_SMTP_HOST=smtp.gmail.com
WL_SMTP_PORT=587
WL_SMTP_USER=                          # <-- YOUR Gmail address (e.g. you@gmail.com)
WL_SMTP_PASS=                          # <-- YOUR 16-char App Password
WL_SMTP_USE_TLS=true

# --- Email addresses ------------------------------------------------
WL_EMAIL_FROM=                         # <-- Sender (same as WL_SMTP_USER)
WL_EMAIL_TO=                           # <-- Recipient (comma-separated if multiple)
